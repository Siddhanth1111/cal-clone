generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Booking {
  id            String   @id @default(uuid())
  bookerName    String
  bookerEmail   String
  notes         String?  // Made optional in case they leave it blank
  startTime     DateTime
  endTime       DateTime
  status        String   @default("CONFIRMED") 
  
  eventTypeId   String   
  userId        String   

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}